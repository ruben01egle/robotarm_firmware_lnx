{
  "configurations": [
    {
      "name": "ROS",
      "compilerPath": "/usr/bin/gcc",
      "cStandard": "gnu11",
      "cppStandard": "c++17",
      "intelliSenseMode": "gcc-x64",
      "compileCommands": "${workspaceFolder}/build/moteus_interface/compile_commands.json",
      "includePath": [
        "/opt/ros/jazzy/include/**",
        "/robotarm_firmware_lnx/src/moteus_interface/include/**",
        "/usr/include/**"
      ],
      "browse": {
        "databaseFilename": "${default}",
        "limitSymbolsToIncludedHeaders": false
      }
    }
  ],
  "version": 4
}