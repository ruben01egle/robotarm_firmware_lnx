{
    "name": "Robotarm Dev Environment (Headless)",
    "build": {
        "context": "..",
        "dockerfile": "./Dockerfile"
    },
    "workspaceFolder": "/robotarm_firmware_lnx",
        
    "runArgs": [
        "--privileged",
        "--net=host",
        "--ipc=host",
        "--cap-add=sys_nice",
        "--ulimit", "rtprio=99",
        "--ulimit", "memlock=-1"
    ],

    "mounts": [
        "source=${localWorkspaceFolder},target=/robotarm_firmware_lnx,type=bind",
        "source=/etc/localtime,target=/etc/localtime,type=bind,ro"
    ],

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-iot.vscode-ros",
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools-extension-pack",
                "redhat.vscode-xml",
                "redhat.vscode-yaml"
            ]
        }
    },

    "remoteUser": "root"
}